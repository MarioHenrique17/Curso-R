#Exercício 4
plot(tabela$altura_cm, tabela$peso_kg, 
     xlab = "Altura (cm)", ylab = "Peso (kg)",
     main = "Dispersão Peso vs Altura",
     pch = 19, col = "Blue")
mod <- lm(peso_kg ~ altura_cm, data = tabela) # Utilizando a função linear model (lm) buscando encontrar a tendência dos dados de peso em relação à altura
resid_pad <- rstandard(mod) # Padronização dos valores do modelo linear para encontrar os outliers.
outlier_relacao <- which(abs(resid_pad) > 2) # Dizer que qualquer valor padronizado maior que 2 é um outlier. O abs é para tornar os valores absolutos, ou seja, -2 se torna 2.
points(tabela$altura_cm[outlier_relacao], tabela$peso_kg[outlier_relacao], 
       col = "red", pch = 19, cex = 1.2) # Aqui serve para selecionar apenas os pontos que se encaixem nas condições da linha anterior e pintá-los de outra cor.
legend("topleft", legend = c("Dados normais", "Outliers na relação"), 
       col = c("Blue", "red"), pch = 19)

#Exercício 5
meu_histograma <- function(dados, titulo, cor) {
                  p_valor <- shapiro.test(dados)$p.value
                  status <- ifelse(p_valor < 0.05, "NÃO Normal", "Normal")
                  mensagem <- paste("p-valor =", round(p_valor, 4), "-", status)
                  hist(dados, main = titulo, xlab = titulo, ylab = "Frequência", col = cor, 
                       sub = mensagem)} #Com essa função, ao gerar o histograma, ja calcula o p diz se a distribuição é normal.
par(mfrow = c(1, 3), mar = c(6, 4, 4, 2))
meu_histograma(dados = tabela$Age,       titulo = "Idade",    cor = "green")
meu_histograma(dados = tabela$peso_kg,   titulo = "Peso",     cor = "red")
meu_histograma(dados = tabela$altura_cm, titulo = "Estatura", cor = "blue")

