#Exercício 11
par(mfrow=c(4,5), mar=c(2,2,2,2))
print("--- Testes de Normalidade de Shapiro-Wilk ---")
for (coluna in names(tabela)) {
  if (is.numeric(tabela[[coluna]]) & coluna != "grupos_idade") {
      qqnorm(tabela[[coluna]], main=coluna)
      qqline(tabela[[coluna]], col="red")
      cat("\nVariável:", coluna, "\n") # Teste Estatístico (p-valor < 0.05 indica que NÃO é normal). Colocando dessa forma, o R já faz os graficos pra todas as variáveis, assim como o teste estatístico.
      print(shapiro.test(tabela[[coluna]]))}}

#Exercício 12
print("--- Testes de Comparação de Médias (Test-t) ---")
for (coluna in names(tabela)) { #Utilizando a função for agiliza o processo
  if (is.numeric(tabela[[coluna]]) & coluna != "grupos_idade") {
    cat("\nComparação para a variável:", coluna, "\n") #Para organizar, mostra sobre qual variável os dados se referem.
    print(t.test(tabela[[coluna]] ~ tabela$grupos_idade, data=tabela))}} # Utilizando o T-test, visto que no exercício anterior, os dados mostraram distribuição próxima da normalidade.


